{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Node",
    "resolveJsonModule": true,
    "isolatedModules": false,
    "noEmit": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    
    // Experimental options
    "experimentalDecorators": true,  // Enables experimental support for decorators
    "emitDecoratorMetadata": true,   // Enables experimental support for emitting decorator metadata
    "importsNotUsedAsValues": "preserve"  // Experimental - Keep unused imports
  },
  "include": ["src"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
